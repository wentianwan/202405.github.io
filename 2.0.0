<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>2024级5班翻转课堂点名系统</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "Microsoft YaHei", sans-serif;
        }

        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            transition: all 0.5s ease;
        }

        .container {
            max-width: 1200px;
            width: 100%;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
            padding: 30px;
            position: relative;
            overflow: hidden;
        }

        .header {
            text-align: center;
            margin-bottom: 30px;
            position: relative;
        }

        .header h1 {
            font-size: 2.5rem;
            color: #333;
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.1);
        }

        .date-time {
            font-size: 1.2rem;
            color: #666;
            margin-bottom: 20px;
        }

        .main-content {
            display: grid;
            grid-template-columns: 1fr 300px;
            gap: 30px;
            margin-bottom: 30px;
        }

        .name-display {
            background: rgba(255, 255, 255, 0.8);
            border-radius: 15px;
            padding: 40px;
            text-align: center;
            box-shadow: inset 0 0 20px rgba(0, 0, 0, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.3);
            min-height: 300px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        .name-display::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(45deg, transparent, rgba(255, 255, 255, 0.5), transparent);
            transform: translateX(-100%);
            transition: transform 0.6s;
        }

        .name-display.animating::before {
            transform: translateX(100%);
        }

        .current-name {
            font-size: 4rem;
            font-weight: bold;
            color: #2c3e50;
            text-shadow: 3px 3px 6px rgba(0, 0, 0, 0.1);
            transition: all 0.3s ease;
        }

        .controls {
            display: flex;
            gap: 20px;
            justify-content: center;
            margin: 30px 0;
        }

        .btn {
            padding: 15px 40px;
            font-size: 1.2rem;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
        }

        .btn-start {
            background: linear-gradient(45deg, #4CAF50, #45a049);
            color: white;
        }

        .btn-reset {
            background: linear-gradient(45deg, #f44336, #da190b);
            color: white;
        }

        .btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: scale(0.95);
        }

        .btn:hover:not(:disabled) {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
        }

        .history-panel {
            background: rgba(255, 255, 255, 0.9);
            border-radius: 15px;
            padding: 20px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        }

        .history-panel h3 {
            text-align: center;
            margin-bottom: 20px;
            color: #333;
            font-size: 1.3rem;
        }

        .history-list {
            list-style: none;
            max-height: 400px;
            overflow-y: auto;
        }

        .history-item {
            padding: 12px 15px;
            margin: 8px 0;
            background: rgba(255, 255, 255, 0.7);
            border-radius: 10px;
            border-left: 4px solid #4CAF50;
            font-size: 1.1rem;
            color: #333;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            transition: all 0.3s ease;
        }

        .history-item:hover {
            transform: translateX(5px);
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.15);
        }

        .birthday-message {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) scale(0);
            background: linear-gradient(45deg, #FFD700, #FFA500);
            padding: 30px 60px;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
            z-index: 1000;
            text-align: center;
            transition: all 0.5s ease;
        }

        .birthday-message.active {
            transform: translate(-50%, -50%) scale(1);
        }

        .birthday-message h2 {
            font-size: 2.5rem;
            color: #8B4513;
            margin-bottom: 10px;
        }

        .birthday-message p {
            font-size: 1.5rem;
            color: #8B4513;
        }

        .stars {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 10;
            opacity: 0;
            transition: opacity 0.5s ease;
        }

        .star {
            position: absolute;
            background: gold;
            border-radius: 50%;
            animation: twinkle 1s infinite alternate;
        }

        @keyframes twinkle {
            0% { opacity: 0.3; transform: scale(0.8); }
            100% { opacity: 1; transform: scale(1.2); }
        }

        .dark-theme {
            background: linear-gradient(135deg, #2c3e50 0%, #34495e 100%);
        }

        .dark-theme .container {
            background: rgba(52, 73, 94, 0.95);
            color: #ecf0f1;
        }

        .dark-theme .name-display {
            background: rgba(44, 62, 80, 0.8);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .dark-theme .current-name {
            color: #ecf0f1;
        }

        .dark-theme .history-panel {
            background: rgba(44, 62, 80, 0.9);
            color: #ecf0f1;
        }

        .dark-theme .history-item {
            background: rgba(52, 73, 94, 0.7);
            color: #ecf0f1;
        }

        .copyright {
            text-align: center;
            margin-top: 20px;
            color: #7f8c8d;
            font-size: 0.9rem;
        }

        @media (max-width: 768px) {
            .main-content {
                grid-template-columns: 1fr;
            }
            
            .header h1 {
                font-size: 2rem;
            }
            
            .current-name {
                font-size: 3rem;
            }
            
            .btn {
                padding: 12px 30px;
                font-size: 1rem;
            }
        }

        @media (max-width: 480px) {
            .container {
                padding: 15px;
            }
            
            .header h1 {
                font-size: 1.8rem;
            }
            
            .current-name {
                font-size: 2.5rem;
            }
            
            .controls {
                flex-direction: column;
                align-items: center;
            }
            
            .btn {
                width: 100%;
                max-width: 200px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>2024级5班翻转课堂点名系统</h1>
            <div class="date-time" id="currentDateTime"></div>
        </div>
        
        <div class="main-content">
            <div class="name-display">
                <div class="current-name" id="currentName">准备开始</div>
                <div class="stars" id="starsContainer"></div>
            </div>
            
            <div class="history-panel">
                <h3>抽中历史</h3>
                <ul class="history-list" id="historyList"></ul>
            </div>
        </div>
        
        <div class="controls">
            <button class="btn btn-start" id="startBtn">开始抽选</button>
            <button class="btn btn-reset" id="resetBtn">重置系统</button>
        </div>
        
        <div class="copyright">
            版权所有 © 2024 翻转课堂点名系统
        </div>
    </div>
    
    <div class="birthday-message" id="birthdayMessage">
        <h2>🎂 生日快乐！</h2>
        <p id="birthdayText"></p>
    </div>

    <script>
        let students = [];
        let quotes = [];
        let isDrawing = false;
        let currentIndex = 0;
        let drawInterval;
        let selectedStudent = null;
        let drawHistory = [];
        let today = new Date();
        let currentMonth = today.getMonth() + 1;
        let currentDay = today.getDate();

        const currentNameElement = document.getElementById('currentName');
        const startBtn = document.getElementById('startBtn');
        const resetBtn = document.getElementById('resetBtn');
        const historyList = document.getElementById('historyList');
        const birthdayMessage = document.getElementById('birthdayMessage');
        const birthdayText = document.getElementById('birthdayText');
        const starsContainer = document.getElementById('starsContainer');
        const currentDateTimeElement = document.getElementById('currentDateTime');

        function updateDateTime() {
            const now = new Date();
            const options = { 
                year: 'numeric', 
                month: 'long', 
                day: 'numeric', 
                weekday: 'long',
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit'
            };
            currentDateTimeElement.textContent = now.toLocaleDateString('zh-CN', options);
        }

        setInterval(updateDateTime, 1000);
        updateDateTime();

        async function fetchData() {
            try {
                const studentsResponse = await fetch('链接1');
                students = await studentsResponse.json();
                
                const quotesResponse = await fetch('链接2');
                quotes = await quotesResponse.json();
                
                console.log('数据加载成功');
            } catch (error) {
                console.error('数据加载失败，1秒后重试:', error);
                setTimeout(fetchData, 1000);
            }
        }

        function createStars() {
            starsContainer.innerHTML = '';
            starsContainer.style.opacity = '1';
            
            for (let i = 0; i < 50; i++) {
                const star = document.createElement('div');
                star.className = 'star';
                star.style.width = Math.random() * 10 + 5 + 'px';
                star.style.height = star.style.width;
                star.style.left = Math.random() * 100 + '%';
                star.style.top = Math.random() * 100 + '%';
                star.style.animationDelay = Math.random() * 2 + 's';
                starsContainer.appendChild(star);
            }
        }

        function removeStars() {
            starsContainer.style.opacity = '0';
            setTimeout(() => {
                starsContainer.innerHTML = '';
            }, 500);
        }

        function getRandomStudent() {
            const validStudents = students.filter(student => {
                const birthDate = new Date(student.birthDate);
                const birthMonth = birthDate.getMonth() + 1;
                const birthDay = birthDate.getDate();
                
                let displayProb = student.displayProbability;
                let drawProb = student.drawProbability;
                
                if (birthMonth === currentMonth && birthDay === currentDay) {
                    displayProb += 0.6589;
                }
                
                return displayProb > 0 || drawProb > 0;
            });

            if (validStudents.length === 0) return null;

            const totalWeight = validStudents.reduce((sum, student) => {
                let drawProb = student.drawProbability;
                
                const birthDate = new Date(student.birthDate);
                const birthMonth = birthDate.getMonth() + 1;
                const birthDay = birthDate.getDate();
                
                if (birthMonth === currentMonth && birthDay === currentDay) {
                    drawProb += 0.6589;
                }
                
                const recentHistory = drawHistory.slice(-5);
                if (recentHistory.includes(student.name)) {
                    drawProb += 0.0013;
                }
                
                return sum + Math.max(drawProb, 0);
            }, 0);

            let random = Math.random() * totalWeight;
            let weightSum = 0;

            for (const student of validStudents) {
                let drawProb = student.drawProbability;
                
                const birthDate = new Date(student.birthDate);
                const birthMonth = birthDate.getMonth() + 1;
                const birthDay = birthDate.getDate();
                
                if (birthMonth === currentMonth && birthDay === currentDay) {
                    drawProb += 0.6589;
                }
                
                const recentHistory = drawHistory.slice(-5);
                if (recentHistory.includes(student.name)) {
                    drawProb += 0.0013;
                }
                
                weightSum += Math.max(drawProb, 0);
                
                if (random <= weightSum) {
                    return student;
                }
            }

            return validStudents[validStudents.length - 1];
        }

        function startDrawing() {
            if (isDrawing || students.length === 0) return;
            
            isDrawing = true;
            startBtn.disabled = true;
            document.body.classList.add('dark-theme');
            createStars();
            
            let displayCount = 0;
            const maxDisplays = 7;
            const displayTime = 1100 / maxDisplays;
            
            drawInterval = setInterval(() => {
                const student = getRandomStudent();
                if (student) {
                    currentNameElement.textContent = student.name;
                    currentNameElement.parentElement.classList.add('animating');
                    
                    setTimeout(() => {
                        currentNameElement.parentElement.classList.remove('animating');
                    }, 300);
                }
                
                displayCount++;
                
                if (displayCount >= maxDisplays) {
                    clearInterval(drawInterval);
                    
                    setTimeout(() => {
                        selectedStudent = getRandomStudent();
                        if (selectedStudent) {
                            currentNameElement.textContent = selectedStudent.name;
                            
                            const birthDate = new Date(selectedStudent.birthDate);
                            const birthMonth = birthDate.getMonth() + 1;
                            const birthDay = birthDate.getDate();
                            
                            if (birthMonth === currentMonth && birthDay === currentDay) {
                                birthdayText.textContent = `${selectedStudent.name}同学生日快乐！`;
                                birthdayMessage.classList.add('active');
                                
                                setTimeout(() => {
                                    birthdayMessage.classList.remove('active');
                                    finishDrawing();
                                }, 3000);
                            } else {
                                setTimeout(finishDrawing, 200);
                            }
                        } else {
                            finishDrawing();
                        }
                    }, 200);
                }
            }, displayTime);
        }

        function finishDrawing() {
            if (selectedStudent) {
                if (!drawHistory.slice(-13).includes(selectedStudent.name)) {
                    drawHistory.push(selectedStudent.name);
                    
                    if (drawHistory.length > 13) {
                        drawHistory = drawHistory.slice(-13);
                    }
                    
                    updateHistoryList();
                }
            }
            
            document.body.classList.remove('dark-theme');
            removeStars();
            
            setTimeout(() => {
                isDrawing = false;
                startBtn.disabled = false;
                selectedStudent = null;
            }, 500);
        }

        function updateHistoryList() {
            historyList.innerHTML = '';
            const uniqueHistory = [];
            
            for (let i = drawHistory.length - 1; i >= 0; i--) {
                if (!uniqueHistory.includes(drawHistory[i]) && uniqueHistory.length < 10) {
                    uniqueHistory.push(drawHistory[i]);
                }
            }
            
            uniqueHistory.forEach(name => {
                const li = document.createElement('li');
                li.className = 'history-item';
                li.textContent = name;
                historyList.appendChild(li);
            });
        }

        function resetSystem() {
            if (isDrawing) {
                clearInterval(drawInterval);
                isDrawing = false;
                document.body.classList.remove('dark-theme');
                removeStars();
                birthdayMessage.classList.remove('active');
            }
            
            currentNameElement.textContent = '准备开始';
            drawHistory = [];
            updateHistoryList();
            startBtn.disabled = false;
            selectedStudent = null;
        }

        startBtn.addEventListener('click', startDrawing);
        resetBtn.addEventListener('click', resetSystem);

        if (window.console || window.console.firebug) {
            window.location.href = '链接3';
        }

        fetchData();
    </script>
</body>
</html>
