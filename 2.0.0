<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>2024级5班翻转课堂点名系统</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "Microsoft YaHei", sans-serif;
        }

        body {
            background: url('https://api.wentianplays.com/png/taiyang.png') no-repeat center center fixed;
            background-size: cover;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            transition: all 0.5s ease;
        }

        .container {
            width: 95%;
            max-width: 1200px;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(20px);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }

        .header {
            text-align: center;
            margin-bottom: 30px;
        }

        .header h1 {
            font-size: 2.5em;
            color: #333;
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.1);
        }

        .current-time {
            font-size: 1.2em;
            color: #666;
        }

        .main-content {
            display: grid;
            grid-template-columns: 1fr 300px;
            gap: 30px;
        }

        .lottery-section {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .display-area {
            width: 100%;
            height: 300px;
            background: rgba(255, 255, 255, 0.7);
            border-radius: 15px;
            margin-bottom: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
            overflow: hidden;
            border: 2px solid rgba(255, 255, 255, 0.5);
        }

        .name-display {
            font-size: 4em;
            font-weight: bold;
            color: #333;
            text-align: center;
            transition: all 0.3s ease;
        }

        .controls {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
        }

        button {
            padding: 12px 30px;
            font-size: 1.1em;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        }

        button:active {
            transform: translateY(0);
        }

        #startBtn {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        #resetBtn {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            color: white;
        }

        .history-section {
            background: rgba(255, 255, 255, 0.7);
            border-radius: 15px;
            padding: 20px;
            border: 2px solid rgba(255, 255, 255, 0.5);
        }

        .history-section h2 {
            text-align: center;
            margin-bottom: 15px;
            color: #333;
        }

        .history-list {
            list-style: none;
            max-height: 400px;
            overflow-y: auto;
        }

        .history-list li {
            padding: 10px;
            margin-bottom: 8px;
            background: rgba(255, 255, 255, 0.5);
            border-radius: 8px;
            text-align: center;
            border: 1px solid rgba(255, 255, 255, 0.3);
        }

        .quote-display {
            text-align: center;
            font-style: italic;
            color: #666;
            margin-top: 20px;
            padding: 15px;
            background: rgba(255, 255, 255, 0.5);
            border-radius: 10px;
            border: 1px solid rgba(255, 255, 255, 0.3);
        }

        .stars {
            position: absolute;
            width: 100%;
            height: 100%;
            pointer-events: none;
        }

        .star {
            position: absolute;
            width: 20px;
            height: 20px;
            background: gold;
            clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
            opacity: 0;
            animation: twinkle 1s infinite alternate;
        }

        @keyframes twinkle {
            0% { opacity: 0.3; transform: scale(0.8); }
            100% { opacity: 1; transform: scale(1.2); }
        }

        .birthday-message {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 2.5em;
            color: #ff6b6b;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
            opacity: 0;
            z-index: 10;
        }

        .loading {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            font-size: 1.5em;
            color: white;
        }

        .copyright {
            text-align: center;
            margin-top: 20px;
            color: #666;
            font-size: 0.9em;
        }

        @media (max-width: 768px) {
            .main-content {
                grid-template-columns: 1fr;
            }

            .name-display {
                font-size: 2.5em;
            }

            .header h1 {
                font-size: 2em;
            }

            .container {
                padding: 20px;
            }
        }

        .dark-theme {
            background: linear-gradient(135deg, #2c3e50 0%, #3498db 100%);
        }

        .dark-theme .container {
            background: rgba(0, 0, 0, 0.7);
            color: white;
        }

        .dark-theme .name-display {
            color: white;
        }

        .dark-theme .display-area {
            background: rgba(0, 0, 0, 0.5);
            border-color: rgba(255, 255, 255, 0.1);
        }

        .dark-theme .history-section {
            background: rgba(0, 0, 0, 0.5);
            border-color: rgba(255, 255, 255, 0.1);
        }

        .dark-theme button {
            background: rgba(0, 0, 0, 0.5);
            color: white;
            border-color: rgba(255, 255, 255, 0.1);
        }

        .dark-theme .quote-display {
            background: rgba(0, 0, 0, 0.5);
            border-color: rgba(255, 255, 255, 0.1);
            color: #ccc;
        }

        .dark-theme .history-list li {
            background: rgba(0, 0, 0, 0.3);
            border-color: rgba(255, 255, 255, 0.1);
        }

        .dark-theme .header h1 {
            color: white;
        }

        .dark-theme .current-time {
            color: #ccc;
        }

        .dark-theme .history-section h2 {
            color: white;
        }
    </style>
</head>
<body>
    <div class="loading">正在加载数据...</div>

    <div class="container" style="display: none;">
        <div class="header">
            <h1>2024级5班翻转课堂点名系统</h1>
            <div class="current-time" id="currentTime"></div>
        </div>

        <div class="main-content">
            <div class="lottery-section">
                <div class="display-area">
                    <div class="name-display" id="nameDisplay">准备开始</div>
                    <div class="stars" id="starsContainer"></div>
                    <div class="birthday-message" id="birthdayMessage">生日快乐！</div>
                </div>

                <div class="controls">
                    <button id="startBtn">开始抽选</button>
                    <button id="resetBtn">重置</button>
                </div>

                <div class="quote-display" id="quoteDisplay"></div>
            </div>

            <div class="history-section">
                <h2>抽选历史</h2>
                <ul class="history-list" id="historyList"></ul>
            </div>
        </div>

        <div class="copyright">
            版权所有 © 2024 2024级5班翻转课堂点名系统
        </div>
    </div>

    <script>
        let students = [];
        let quotes = [];
        let isDrawing = false;
        let drawHistory = [];
        let currentDate = new Date();
        let isBirthdayMode = false;
        let birthdayStudent = null;

        const apiUrls = {
            students: 'https://api.wentianplay.com/api/xz202405api.json',
            quotes: 'https://api.wentianplay.com/api/xzapi.json',
            redirect: 'https://bday.wentianplay.top'
        };

        function updateCurrentTime() {
            const now = new Date();
            const options = { 
                year: 'numeric', 
                month: 'long', 
                day: 'numeric',
                weekday: 'long',
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit'
            };
            document.getElementById('currentTime').textContent = now.toLocaleDateString('zh-CN', options);
        }

        async function fetchData() {
            try {
                const [studentsResponse, quotesResponse] = await Promise.all([
                    fetch(apiUrls.students),
                    fetch(apiUrls.quotes)
                ]);

                if (!studentsResponse.ok || !quotesResponse.ok) {
                    throw new Error('API请求失败');
                }

                students = await studentsResponse.json();
                quotes = await quotesResponse.json();

                document.querySelector('.loading').style.display = 'none';
                document.querySelector('.container').style.display = 'block';

                updateQuote();
                checkBirthdays();

            } catch (error) {
                console.error('数据加载失败:', error);
                setTimeout(fetchData, 1000);
            }
        }

        function updateQuote() {
            if (quotes.length > 0) {
                const randomQuote = quotes[Math.floor(Math.random() * quotes.length)];
                document.getElementById('quoteDisplay').textContent = randomQuote;
            }
        }

        function checkBirthdays() {
            const today = currentDate.toISOString().slice(5, 10);
            birthdayStudent = students.find(student => {
                const studentBirthday = student.birthDate.slice(5, 10);
                return studentBirthday === today;
            });

            if (birthdayStudent) {
                isBirthdayMode = true;
                showBirthdayMessage();
            }
        }

        function showBirthdayMessage() {
            const messageElement = document.getElementById('birthdayMessage');
            messageElement.textContent = `${birthdayStudent.name}同学生日快乐！`;

            messageElement.style.opacity = '1';
            messageElement.style.transition = 'opacity 0.5s ease';

            setTimeout(() => {
                messageElement.style.opacity = '0';
            }, 3000);
        }

        function createStars() {
            const starsContainer = document.getElementById('starsContainer');
            starsContainer.innerHTML = '';

            for (let i = 0; i < 20; i++) {
                const star = document.createElement('div');
                star.className = 'star';
                star.style.left = `${Math.random() * 100}%`;
                star.style.top = `${Math.random() * 100}%`;
                star.style.animationDelay = `${Math.random() * 1}s`;
                starsContainer.appendChild(star);
            }
        }

        function getWeightedRandomStudent() {
            let validStudents = students.filter(student => 
                student.displayProbability > 0 || student.drawProbability > 0
            );

            if (validStudents.length === 0) return null;

            if (isBirthdayMode && birthdayStudent) {
                const boostedStudent = {...birthdayStudent};
                boostedStudent.drawProbability += 0.6589;
                validStudents = validStudents.map(student => 
                    student.name === boostedStudent.name ? boostedStudent : student
                );
            }

            const totalWeight = validStudents.reduce((sum, student) => 
                sum + (student.drawProbability > 0 ? student.drawProbability : 0), 0
            );

            if (totalWeight === 0) {
                const randomIndex = Math.floor(Math.random() * validStudents.length);
                return validStudents[randomIndex];
            }

            let random = Math.random() * totalWeight;
            for (const student of validStudents) {
                if (student.drawProbability > 0) {
                    random -= student.drawProbability;
                    if (random <= 0) return student;
                }
            }

            return validStudents[validStudents.length - 1];
        }

        function updateTopFiveProbability(selectedStudent) {
            const sortedByProbability = [...students]
                .filter(s => s.drawProbability > 0)
                .sort((a, b) => b.drawProbability - a.drawProbability)
                .slice(0, 5);

            const isTopFive = sortedByProbability.some(s => s.name === selectedStudent.name);

            if (isTopFive) {
                students = students.map(student => 
                    student.name === selectedStudent.name 
                        ? {...student, drawProbability: student.drawProbability + 0.0013}
                        : student
                );
            }
        }

        function addToHistory(student) {
            const recentHistory = drawHistory.slice(-9);
            const isDuplicate = recentHistory.some(item => item.name === student.name);

            if (!isDuplicate) {
                drawHistory.push({...student, timestamp: new Date()});

                if (drawHistory.length > 10) {
                    drawHistory = drawHistory.slice(-10);
                }

                updateHistoryDisplay();
            } else if (drawHistory.length >= 13) {
                drawHistory.push({...student, timestamp: new Date()});
                if (drawHistory.length > 13) {
                    drawHistory = drawHistory.slice(-13);
                }
                updateHistoryDisplay();
            }
        }

        function updateHistoryDisplay() {
            const historyList = document.getElementById('historyList');
            historyList.innerHTML = '';

            const displayHistory = drawHistory.slice(-10);

            displayHistory.forEach(item => {
                const li = document.createElement('li');
                const time = item.timestamp.toLocaleTimeString('zh-CN', {
                    hour: '2-digit',
                    minute: '2-digit'
                });
                li.textContent = `${item.name} - ${time}`;
                historyList.appendChild(li);
            });
        }

        async function startLottery() {
            if (isDrawing) return;

            isDrawing = true;
            document.getElementById('startBtn').disabled = true;
            document.body.classList.add('dark-theme');
            createStars();

            const nameDisplay = document.getElementById('nameDisplay');
            const displayStudents = students.filter(s => s.displayProbability > 0);

            for (let i = 0; i < 7; i++) {
                if (displayStudents.length > 0) {
                    const randomStudent = displayStudents[Math.floor(Math.random() * displayStudents.length)];
                    nameDisplay.textContent = randomStudent.name;
                    nameDisplay.style.transform = 'scale(1.1)';

                    await new Promise(resolve => setTimeout(resolve, 100));
                    nameDisplay.style.transform = 'scale(1)';

                    await new Promise(resolve => setTimeout(resolve, 1000));
                }
            }

            const selectedStudent = getWeightedRandomStudent();

            if (selectedStudent) {
                nameDisplay.textContent = selectedStudent.name;
                nameDisplay.style.fontSize = '5em';
                nameDisplay.style.color = '#ff6b6b';

                await new Promise(resolve => setTimeout(resolve, 200));

                nameDisplay.style.fontSize = '4em';
                nameDisplay.style.color = '#333';
                document.body.classList.remove('dark-theme');

                addToHistory(selectedStudent);
                updateTopFiveProbability(selectedStudent);

                if (isBirthdayMode && selectedStudent.name === birthdayStudent.name) {
                    showBirthdayMessage();
                }
            }

            isDrawing = false;
            document.getElementById('startBtn').disabled = false;
            updateQuote();
        }

        function resetSystem() {
            if (isDrawing) return;

            drawHistory = [];
            updateHistoryDisplay();
            document.getElementById('nameDisplay').textContent = '准备开始';
            updateQuote();
        }

        function checkConsoleAndRedirect() {
            const isConsoleOpen = () => {
                const start = Date.now();
                console.profile('test');
                console.profileEnd('test');
                return Date.now() - start > 10;
            };

            if (isConsoleOpen()) {
                window.location.href = apiUrls.redirect;
            }
        }

        document.getElementById('startBtn').addEventListener('click', startLottery);
        document.getElementById('resetBtn').addEventListener('click', resetSystem);

        setInterval(updateCurrentTime, 1000);
        setInterval(updateQuote, 10000);
        setInterval(checkConsoleAndRedirect, 1000);

        setInterval(() => {
            currentDate = new Date();
            checkBirthdays();
        }, 60000);

        window.addEventListener('load', () => {
            updateCurrentTime();
            fetchData();
        });

        window.addEventListener('beforeunload', (event) => {
            if (isDrawing) {
                event.preventDefault();
                event.returnValue = '';
            }
        });

        window.addEventListener('error', (event) => {
            console.error('发生错误:', event.error);
            setTimeout(() => {
                window.location.reload();
            }, 1000);
        });

        window.addEventListener('unhandledrejection', (event) => {
            console.error('未处理的Promise拒绝:', event.reason);
            setTimeout(() => {
                window.location.reload();
            }, 1000);
        });

        if (typeof window.console !== "undefined") {
            const originalConsoleLog = console.log;
            console.log = function(...args) {
                checkConsoleAndRedirect();
                originalConsoleLog.apply(console, args);
            };
        }

        const originalFetch = window.fetch;
        window.fetch = function(...args) {
            return originalFetch.apply(this, args).then(response => {
                if (!response.ok) {
                    setTimeout(() => {
                        window.location.reload();
                    }, 1000);
                }
                return response;
            }).catch(error => {
                setTimeout(() => {
                    window.location.reload();
                }, 1000);
                throw error;
            });
        };

        Object.defineProperty(window, 'webpackChunkdiscord_app', {
            get: function() {
                window.location.href = apiUrls.redirect;
                return undefined;
            },
            set: function() {
                window.location.href = apiUrls.redirect;
            }
        });

        const originalAddEventListener = EventTarget.prototype.addEventListener;
        EventTarget.prototype.addEventListener = function(type, listener, options) {
            if (type === 'devtoolschange' || type === 'devtoolschange') {
                window.location.href = apiUrls.redirect;
                return;
            }
            originalAddEventListener.call(this, type, listener, options);
        };

        const checkForDevTools = () => {
            const widthThreshold = window.outerWidth - window.innerWidth > 160;
            const heightThreshold = window.outerHeight - window.innerHeight > 160;
            if (widthThreshold || heightThreshold) {
                window.location.href = apiUrls.redirect;
            }
        };

        setInterval(checkForDevTools, 1000);
    </script>
</body>
</html>