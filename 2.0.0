<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>2024级5班翻转课堂点名系统</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "Microsoft YaHei", sans-serif;
        }

        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            transition: all 0.5s ease;
        }

        .container {
            width: 100%;
            max-width: 800px;
            background: rgba(255, 255, 255, 0.25);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 8px 32px rgba(31, 38, 135, 0.2);
            border: 1px solid rgba(255, 255, 255, 0.18);
        }

        .header {
            text-align: center;
            margin-bottom: 30px;
        }

        .header h1 {
            color: #333;
            font-size: clamp(1.5rem, 4vw, 2.2rem);
            margin-bottom: 10px;
        }

        .quote-display {
            color: #666;
            font-size: clamp(0.9rem, 2vw, 1.1rem);
            min-height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
        }

        .name-display {
            background: rgba(255, 255, 255, 0.3);
            border-radius: 15px;
            padding: 40px 20px;
            margin: 30px 0;
            text-align: center;
            min-height: 200px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        .current-name {
            font-size: clamp(2rem, 8vw, 4rem);
            color: #333;
            font-weight: bold;
            transition: all 0.3s ease;
        }

        .controls {
            display: flex;
            gap: 20px;
            justify-content: center;
            margin: 30px 0;
        }

        button {
            padding: 12px 30px;
            border: none;
            border-radius: 25px;
            font-size: 1.1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            background: rgba(255, 255, 255, 0.3);
            backdrop-filter: blur(10px);
            color: #333;
            font-weight: bold;
        }

        button:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
        }

        button:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .history-section {
            margin-top: 30px;
        }

        .history-title {
            color: #333;
            font-size: 1.2rem;
            margin-bottom: 15px;
            text-align: center;
        }

        .history-names {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            justify-content: center;
        }

        .history-name {
            background: rgba(255, 255, 255, 0.3);
            padding: 8px 15px;
            border-radius: 15px;
            font-size: 0.9rem;
        }

        .stars {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
        }

        .star {
            position: absolute;
            background: gold;
            clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
            animation: twinkle 1s infinite alternate;
        }

        @keyframes twinkle {
            0% { opacity: 0.3; transform: scale(0.8); }
            100% { opacity: 1; transform: scale(1.2); }
        }

        .birthday-effect {
            animation: birthdayPulse 0.5s infinite alternate;
        }

        @keyframes birthdayPulse {
            0% { transform: scale(1); color: #ff6b6b; }
            100% { transform: scale(1.1); color: #4ecdc4; }
        }

        .copyright {
            text-align: center;
            margin-top: 20px;
            color: #666;
            font-size: 0.8rem;
        }

        body.dark-theme {
            background: linear-gradient(135deg, #2c3e50 0%, #34495e 100%);
        }

        body.dark-theme .container {
            background: rgba(0, 0, 0, 0.3);
            color: #ecf0f1;
        }

        body.dark-theme .current-name,
        body.dark-theme .header h1,
        body.dark-theme .history-title {
            color: #ecf0f1;
        }

        @media (max-width: 768px) {
            .container {
                padding: 20px;
                margin: 10px;
            }
            
            .controls {
                flex-direction: column;
                align-items: center;
            }
            
            button {
                width: 100%;
                max-width: 200px;
            }
            
            .name-display {
                min-height: 150px;
                padding: 30px 15px;
            }
        }

        @media (max-width: 480px) {
            .history-names {
                gap: 5px;
            }
            
            .history-name {
                padding: 5px 10px;
                font-size: 0.8rem;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>2024级5班翻转课堂点名系统</h1>
            <div class="quote-display" id="quoteDisplay">正在加载名言...</div>
        </div>
        
        <div class="name-display">
            <div class="current-name" id="currentName">准备开始</div>
            <div class="stars" id="starsContainer"></div>
        </div>
        
        <div class="controls">
            <button id="startBtn" onclick="startLottery()">开始抽选</button>
            <button id="resetBtn" onclick="resetSystem()">重置系统</button>
        </div>
        
        <div class="history-section">
            <div class="history-title">最近抽中历史</div>
            <div class="history-names" id="historyNames"></div>
        </div>
        
        <div class="copyright">版权所有 © 2024级5班</div>
    </div>

    <script>
        let students = [];
        let quotes = [];
        let isDrawing = false;
        let currentIndex = 0;
        let drawHistory = [];
        let displayTimeout;
        let drawTimeout;
        let birthdayStudent = null;
        const quotesUrl = 'https://example.com/api/quotes';
        const studentsUrl = 'https://example.com/api/students';
        const birthdayRedirectUrl = 'https://example.com/birthday-countdown';

        async function fetchData() {
            try {
                const [quotesResponse, studentsResponse] = await Promise.all([
                    fetch(quotesUrl),
                    fetch(studentsUrl)
                ]);
                
                if (!quotesResponse.ok || !studentsResponse.ok) {
                    throw new Error('网络请求失败');
                }
                
                quotes = await quotesResponse.json();
                students = await studentsResponse.json();
                
                updateQuote();
                checkBirthday();
                
            } catch (error) {
                console.error('获取数据失败:', error);
                setTimeout(fetchData, 1000);
            }
        }

        function updateQuote() {
            const quoteDisplay = document.getElementById('quoteDisplay');
            if (quotes.length > 0) {
                const randomQuote = quotes[Math.floor(Math.random() * quotes.length)];
                quoteDisplay.textContent = randomQuote;
            }
        }

        function checkBirthday() {
            const today = new Date().toISOString().slice(5, 10);
            birthdayStudent = students.find(student => {
                const studentDate = student.birthDate.slice(5, 10);
                return studentDate === today;
            });
        }

        function startLottery() {
            if (isDrawing || students.length === 0) return;
            
            isDrawing = true;
            document.getElementById('startBtn').disabled = true;
            
            if (birthdayStudent) {
                showBirthdayEffect();
                return;
            }
            
            startNameDisplay();
        }

        function startNameDisplay() {
            const validStudents = students.filter(student => 
                student.displayProbability > 0 || student.drawProbability > 0
            );
            
            if (validStudents.length === 0) {
                isDrawing = false;
                document.getElementById('startBtn').disabled = false;
                return;
            }
            
            let displayCount = 0;
            const maxDisplays = 7;
            const displayedIndices = new Set();
            
            function displayNextName() {
                if (displayCount >= maxDisplays) {
                    finalDraw();
                    return;
                }
                
                let availableStudents = validStudents.filter((_, index) => !displayedIndices.has(index));
                if (availableStudents.length === 0) {
                    availableStudents = validStudents;
                    displayedIndices.clear();
                }
                
                const randomIndex = Math.floor(Math.random() * availableStudents.length);
                const studentIndex = validStudents.indexOf(availableStudents[randomIndex]);
                displayedIndices.add(studentIndex);
                
                const student = validStudents[randomIndex];
                document.getElementById('currentName').textContent = student.name;
                document.getElementById('currentName').classList.remove('birthday-effect');
                
                createStars();
                document.body.classList.add('dark-theme');
                
                displayCount++;
                displayTimeout = setTimeout(displayNextName, 1100);
            }
            
            displayNextName();
        }

        function finalDraw() {
            clearTimeout(displayTimeout);
            
            const drawableStudents = students.filter(student => student.drawProbability > 0);
            if (drawableStudents.length === 0) {
                endLottery();
                return;
            }
            
            const totalProbability = drawableStudents.reduce((sum, student) => sum + student.drawProbability, 0);
            let random = Math.random() * totalProbability;
            let selectedStudent = null;
            
            for (const student of drawableStudents) {
                random -= student.drawProbability;
                if (random <= 0) {
                    selectedStudent = student;
                    break;
                }
            }
            
            if (!selectedStudent) {
                selectedStudent = drawableStudents[drawableStudents.length - 1];
            }
            
            document.getElementById('currentName').textContent = selectedStudent.name;
            
            updateDrawHistory(selectedStudent.name);
            updateStudentProbability(selectedStudent.name);
            
            drawTimeout = setTimeout(() => {
                endLottery();
                updateQuote();
            }, 200);
        }

        function showBirthdayEffect() {
            document.getElementById('currentName').textContent = birthdayStudent.name;
            document.getElementById('currentName').classList.add('birthday-effect');
            document.getElementById('currentName').textContent += ' 🎂 生日快乐！';
            
            createStars();
            document.body.classList.add('dark-theme');
            
            birthdayStudent.displayProbability += 0.6589;
            birthdayStudent.drawProbability += 0.6589;
            
            updateDrawHistory(birthdayStudent.name);
            
            setTimeout(() => {
                endLottery();
                updateQuote();
            }, 3000);
        }

        function endLottery() {
            isDrawing = false;
            document.getElementById('startBtn').disabled = false;
            document.body.classList.remove('dark-theme');
            document.getElementById('currentName').classList.remove('birthday-effect');
            clearStars();
        }

        function resetSystem() {
            if (isDrawing) {
                clearTimeout(displayTimeout);
                clearTimeout(drawTimeout);
                isDrawing = false;
                document.getElementById('startBtn').disabled = false;
                document.body.classList.remove('dark-theme');
                document.getElementById('currentName').classList.remove('birthday-effect');
                clearStars();
            }
            
            document.getElementById('currentName').textContent = '准备开始';
            drawHistory = [];
            updateHistoryDisplay();
            updateQuote();
        }

        function updateDrawHistory(studentName) {
            const recentUnique = [...new Set(drawHistory.slice(-12))].slice(-10);
            
            if (!recentUnique.includes(studentName) || drawHistory.length >= 13) {
                drawHistory.push(studentName);
                if (drawHistory.length > 13) {
                    drawHistory = drawHistory.slice(-13);
                }
            } else {
                drawHistory.push(studentName);
            }
            
            updateHistoryDisplay();
            updateTopStudentsProbability(studentName);
        }

        function updateHistoryDisplay() {
            const historyContainer = document.getElementById('historyNames');
            const recentHistory = [...new Set(drawHistory.slice(-13))].slice(-10);
            
            historyContainer.innerHTML = recentHistory.map(name => 
                `<div class="history-name">${name}</div>`
            ).join('');
        }

        function updateStudentProbability(studentName) {
            const student = students.find(s => s.name === studentName);
            if (student) {
                student.drawProbability = Math.max(0, student.drawProbability - 0.1);
            }
        }

        function updateTopStudentsProbability(selectedName) {
            const topStudents = students
                .filter(s => s.drawProbability > 0)
                .sort((a, b) => b.drawProbability - a.drawProbability)
                .slice(0, 5);
            
            if (topStudents.some(s => s.name === selectedName)) {
                const student = students.find(s => s.name === selectedName);
                if (student) {
                    student.drawProbability += 0.0013;
                }
            }
        }

        function createStars() {
            const container = document.getElementById('starsContainer');
            container.innerHTML = '';
            
            for (let i = 0; i < 20; i++) {
                const star = document.createElement('div');
                star.className = 'star';
                star.style.width = Math.random() * 20 + 10 + 'px';
                star.style.height = star.style.width;
                star.style.left = Math.random() * 100 + '%';
                star.style.top = Math.random() * 100 + '%';
                star.style.animationDelay = Math.random() * 1 + 's';
                container.appendChild(star);
            }
        }

        function clearStars() {
            document.getElementById('starsContainer').innerHTML = '';
        }

        function checkDevTools() {
            const devtools = /./;
            devtools.toString = function() {
                if (!this.opened) {
                    this.opened = true;
                    window.location.href = birthdayRedirectUrl;
                }
                return '';
            };
            console.log('%c', devtools);
        }

        setInterval(checkDevTools, 1000);

        window.addEventListener('load', fetchData);
        setInterval(updateQuote, 10000);
        setInterval(checkBirthday, 60000);
    </script>
</body>
</html>
